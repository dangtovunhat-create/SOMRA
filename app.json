{
  "expo": {
    "name": "SensoryApp",
    "slug": "sensory-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.sensory.app",
      "softwareKeyboardLayoutMode": "pan"
    },
    "ios": {
      "supportsTablet": false
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-audio"
    ]
  }
}
